generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// User & Auth (NextAuth Compatible)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // Custom for credentials auth

  accounts Account[]
  sessions Session[]

  // Custom Application Fields
  role           String        @default("USER")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  tickets          Ticket[]         @relation("AssignedTickets")
  createdTickets   Ticket[]         @relation("CreatedTickets")
  ownedExperiments Experiment[]     @relation("ExperimentOwner")
  createdLearnings Learning[]       @relation("LearningCreator")
  createdSnapshots FunnelSnapshot[] @relation("SnapshotCreator")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users           User[]
  dataSources     DataSource[]
  metrics         Metric[]
  scenarios       Scenario[]
  recommendations Recommendation[]
  experiments     Experiment[]
  funnels         Funnel[]
  learnings       Learning[]
  channels        Channel[]
  utmLinks        UtmLink[]
  alerts          Alert[]
}


// Data Sources & ETL
model DataSource {
  id             String         @id @default(cuid())
  name           String
  type           String
  config         String // API keys, settings (JSON string)
  status         String         @default("ACTIVE")
  lastSyncAt     DateTime?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}


// Core Metrics (AARRR)
model Metric {
  id             String         @id @default(cuid())
  name           String // e.g. "unique_visitors", "signups"
  value          Float
  date           DateTime
  category       String // AARRR stage
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])

  // Optional linkage to source
  sourceId String?

  createdAt DateTime @default(now())
}


// Diagnosis & Recommendations
model Recommendation {
  id             String       @id @default(cuid())
  title          String
  description    String
  impact         String
  status         String    @default("OPEN")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
}


// Project Management / Tickets
model Ticket {
  id               String          @id @default(cuid())
  title            String
  status           String          @default("TODO")
  assigneeId       String?
  assignee         User?           @relation("AssignedTickets", fields: [assigneeId], references: [id])
  reporterId       String
  reporter         User            @relation("CreatedTickets", fields: [reporterId], references: [id])
  recommendationId String?
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Forecasting Scenarios
model Scenario {
  id             String       @id @default(cuid())
  name           String
  description    String?
  parameters     String // Assumptions: { acquisition_growth: 0.1, ... } (JSON string)
  results        String // Forecasted metrics (JSON string)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ─── Growth OS Modules ───────────────────────────────────────────────────────

// Experiment Backlog with ICE/RICE Scoring
model Experiment {
  id             String    @id @default(cuid())
  title          String
  description    String?
  hypothesis     String?
  funnelStage    String    @default("acquisition") // awareness|acquisition|activation|retention|revenue|referral
  status         String    @default("idea")        // idea|backlog|in_progress|paused|completed|archived
  priorityScore  Float?

  // ICE scoring (1-10 each)
  iceImpact      Float?
  iceConfidence  Float?
  iceEase        Float?

  // RICE scoring
  riceReach      Float?
  riceImpact     Float?    // 1-3
  riceConfidence Float?    // 0-100 (percent)
  riceEffort     Float?    // weeks

  ownerId        String?
  owner          User?        @relation("ExperimentOwner", fields: [ownerId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  startedAt      DateTime?
  endedAt        DateTime?
  tags           String    @default("[]") // JSON array of strings
  relatedMetric  String?
  expectedLift   Float?    // percent
  actualLift     Float?    // percent
  result         String?   // win|loss|inconclusive
  learning       String?   // text note at conclusion

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  learnings      Learning[]
  stageLinks     FunnelStageLink[]
}


// Custom Funnel Tracker
model Funnel {
  id             String    @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  stages         String    @default("[]") // JSON: [{name, order, description}]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  snapshots      FunnelSnapshot[]
  stageLinks     FunnelStageLink[]
}

model FunnelSnapshot {
  id           String   @id @default(cuid())
  funnelId     String
  funnel       Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  snapshotDate DateTime
  stageData    String   // JSON: [{stageName, value, unit}]
  notes        String?
  createdById  String?
  createdBy    User?    @relation("SnapshotCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
}

model FunnelStageLink {
  id           String     @id @default(cuid())
  funnelId     String
  funnel       Funnel     @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  stageName    String

  @@unique([funnelId, experimentId])
}


// Learning Log / Knowledge Repository
model Learning {
  id             String      @id @default(cuid())
  experimentId   String?
  experiment     Experiment? @relation(fields: [experimentId], references: [id])
  title          String
  summary        String
  category       String      // copy|ux|pricing|onboarding|activation|retention|channel|other
  funnelStage    String?
  impactLevel    String      @default("medium") // high|medium|low
  resultType     String      // validated|invalidated|inconclusive
  evidence       String?
  recommendation String?
  tags           String      @default("[]") // JSON array
  createdById    String?
  createdBy      User?       @relation("LearningCreator", fields: [createdById], references: [id])
  isPinned       Boolean     @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}


// ─── Channels & Marketing Integrations ─────────────────────────────────────────

model Channel {
  id             String         @id @default(cuid())
  connectorType  String         // google-analytics, google-ads, meta-ads, etc.
  displayName    String         // "Google Analytics 4", "Google Ads", etc.
  status         String         @default("DISCONNECTED") // ACTIVE, PAUSED, ERROR, DISCONNECTED
  credentials    String?        // Encrypted JSON credentials
  config         String?        // Additional configuration (JSON)
  lastSyncAt     DateTime?
  syncFrequency  String         @default("DAILY") // HOURLY, DAILY, WEEKLY
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  
  metrics        ChannelMetrics[]
  spends         Spend[]
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  @@unique([connectorType, organizationId])
}

model ChannelMetrics {
  id             String   @id @default(cuid())
  channelId      String
  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  
  date           DateTime
  source         String   @default("total")
  campaign       String   @default("all")
  adGroup        String?
  country        String?
  device         String?
  
  impressions    Int?
  clicks         Int?
  spend          Decimal? @db.Decimal(12, 2)
  revenue        Decimal? @db.Decimal(12, 2)
  conversions    Int?
  
  users          Int?
  sessions       Int?
  pageviews      Int?
  bounceRate     Decimal? @db.Decimal(5, 4)
  
  ctr            Decimal? @db.Decimal(6, 4)
  cpc            Decimal? @db.Decimal(10, 4)
  cpm            Decimal? @db.Decimal(10, 4)
  roas           Decimal? @db.Decimal(8, 4)
  cpl            Decimal? @db.Decimal(10, 4)
  conversionRate Decimal? @db.Decimal(6, 4)
  
  customMetrics  String?   // JSON for connector-specific metrics
  
  createdAt      DateTime @default(now())
  
  @@unique([channelId, date, source, campaign])
  @@index([channelId, date])
}

model Spend {
  id             String   @id @default(cuid())
  channelId      String
  channel        Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  
  date           DateTime
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("BRL")
  campaignName   String?
  
  createdAt      DateTime @default(now())
  
  @@index([channelId, date])
}

model UtmLink {
  id             String       @id @default(cuid())
  baseUrl        String
  source         String
  medium         String
  campaign       String?
  term           String?
  content        String?
  shortCode      String?      @unique
  clicks         Int          @default(0)
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  @@index([organizationId])
}

model Alert {
  id             String       @id @default(cuid())
  type           String       // BUDGET_80, BUDGET_100, ANOMALY, TEST_COMPLETED, CONVERSION_DROP
  channelId      String?
  message        String
  details        String?      // JSON with additional context
  severity       String       @default("INFO") // INFO, WARNING, CRITICAL
  status         String       @default("ACTIVE") // ACTIVE, ACKNOWLEDGED, RESOLVED, DISMISSED
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?
  
  @@index([organizationId, status])
  @@index([channelId])
}
