generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User & Auth (NextAuth Compatible)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // Custom for credentials auth

  accounts Account[]
  sessions Session[]

  // Custom Application Fields
  role           String        @default("USER")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  tickets        Ticket[] @relation("AssignedTickets")
  createdTickets Ticket[] @relation("CreatedTickets")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("FREE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users           User[]
  dataSources     DataSource[]
  metrics         Metric[]
  scenarios       Scenario[]
  recommendations Recommendation[]
}


// Data Sources & ETL
model DataSource {
  id             String         @id @default(cuid())
  name           String
  type           String
  config         String // API keys, settings (JSON string)
  status         String         @default("ACTIVE")
  lastSyncAt     DateTime?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}


// Core Metrics (AARRR)
model Metric {
  id             String         @id @default(cuid())
  name           String // e.g. "unique_visitors", "signups"
  value          Float
  date           DateTime
  category       String // AARRR stage
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])

  // Optional linkage to source
  sourceId String?

  createdAt DateTime @default(now())
}


// Diagnosis & Recommendations
model Recommendation {
  id             String       @id @default(cuid())
  title          String
  description    String
  impact         String
  status         String    @default("OPEN")
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets Ticket[]
}


// Project Management / Tickets
model Ticket {
  id               String          @id @default(cuid())
  title            String
  status           String          @default("TODO")
  assigneeId       String?
  assignee         User?           @relation("AssignedTickets", fields: [assigneeId], references: [id])
  reporterId       String
  reporter         User            @relation("CreatedTickets", fields: [reporterId], references: [id])
  recommendationId String?
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// Forecasting Scenarios
model Scenario {
  id             String       @id @default(cuid())
  name           String
  description    String?
  parameters     String // Assumptions: { acquisition_growth: 0.1, ... } (JSON string)
  results        String // Forecasted metrics (JSON string)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
